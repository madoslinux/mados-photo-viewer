[Desktop Entry]
Name=madOS Photo Viewer
Comment=Photo viewer and manager
Exec=/usr/local/bin/mados-photo-viewer %f
Icon=image-x-generic
Terminal=false
Type=Application
Categories=Graphics;Viewer;
MimeType=image/png;image/jpeg;image/gif;image/bmp;image/webp;image/svg+xml;
StartupWMClass=mados-photo-viewer
StartupNotify=true
